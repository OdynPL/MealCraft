{
  "name": "mealcraft-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "lint": "ng lint",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.spec.json",
    "analyze:knip": "knip --reporter compact --no-progress",
    "graph:dependencies": "node scripts/generate-dependency-graph.mjs",
    "graph:render": "mmdc -p scripts/mermaid-puppeteer-config.json -i reports/dependency-graph/graph.mmd -o reports/dependency-graph/graph.svg && mmdc -p scripts/mermaid-puppeteer-config.json -i reports/dependency-graph/component-graph.mmd -o reports/dependency-graph/component-graph.svg && mmdc -p scripts/mermaid-puppeteer-config.json -i reports/dependency-graph/component-graph.mmd -o reports/dependency-graph/component-graph.png && mmdc -p scripts/mermaid-puppeteer-config.json -i reports/dependency-graph/component-tree.mmd -o reports/dependency-graph/component-tree.svg && mmdc -p scripts/mermaid-puppeteer-config.json -i reports/dependency-graph/component-tree.mmd -o reports/dependency-graph/component-tree.png",
    "readme:update": "node scripts/update-readme.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "test:ci:coverage": "ng test --watch=false --coverage",
    "sync:photos": "node scripts/sync-real-photos.mjs",
    "sync:photos:force": "node scripts/sync-real-photos.mjs --force"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "knip": {
    "entry": [
      "src/main.ts",
      "eslint.config.js",
      "scripts/sync-real-photos.mjs",
      "scripts/generate-dependency-graph.mjs",
      "scripts/check-bundle-size.mjs",
      "scripts/update-readme.mjs"
    ],
    "project": [
      "src/**/*.ts",
      "src/**/*.html",
      "scripts/**/*.mjs"
    ],
    "ignoreDependencies": [
      "@vitest/coverage-v8"
    ]
  },
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "~21.2.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "~21.2.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.2.0",
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/material": "^21.2.0",
    "@eslint/js": "^9.39.3",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.39.3",
    "jsdom": "^27.1.0",
    "knip": "^5.85.0",
    "madge": "^8.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.8"
  }
}
